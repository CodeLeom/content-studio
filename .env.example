# Copy to `.env.local` and fill in values.
# See README — “If you run the app yourself”.

# Notion OAuth (enables Connect Notion)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Internal integration secret (starts with secret_) — Studio without OAuth.
# Takes priority over any Notion cookie. Restart the server after changing.
# Internal integrations cannot create a workspace-root page: create a Notion page, connect this
# integration to it (… → Connections), then set its ID from the URL (32-char hex):
# NOTION_PARENT_PAGE_ID=
# NOTION_TOKEN=

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
